{
  "name": "auto-test-platform",
  "version": "1.0.0",
  "private": true,
  "description": "自动化测试平台 - 支持接口/Web/UI自动化测试",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "tsx watch src/server/index.ts",
    "agent": "tsx src/agent-web/index.ts",
    "dev:agent": "tsx watch src/agent-web/index.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "build:agent": "tsc -p tsconfig.agent.json",
    "build:agent-mobile": "tsc -p tsconfig.agent-mobile.json",
    "build:agent-pc": "tsc -p tsconfig.agent-pc.json",
    "start": "node dist/server/index.js",
    "start:agent": "node dist/agent-web/index.js",
    "test": "tsx src/server/engine/_phase2_smoke.ts",
    "setup:drivers": "node scripts/install-playwright-drivers.mjs",
    "postinstall": "node scripts/install-playwright-drivers.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@midscene/android": "^1.9.1",
    "@midscene/computer": "^1.9.1",
    "@midscene/core": "^1.9.1",
    "@midscene/harmony": "^1.9.1",
    "@midscene/ios": "^1.9.1",
    "@midscene/web": "^1.9.1",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "@uiw/react-codemirror": "^4.25.9",
    "@xyflow/react": "^12.10.2",
    "@yume-chan/adb": "^2.5.1",
    "@yume-chan/adb-scrcpy": "^2.3.2",
    "@yume-chan/scrcpy": "^2.3.0",
    "@yume-chan/scrcpy-decoder-webcodecs": "^2.5.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "node-cron": "^4.2.1",
    "open": "^10.1.0",
    "pg": "^8.21.0",
    "playwright": "^1.60.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "ssh2": "^1.16.0",
    "swagger-parser": "^10.0.3",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^18.19.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/ssh2": "^1.15.0",
    "@vitejs/plugin-react": "^4.2.1",
    "portfinder": "^1.0.32",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "@tailwindcss/oxide",
      "esbuild",
      "sharp",
      "ssh2",
      "node-mac-permissions"
    ],
    "overrides": {
      "@midscene/core": "workspace:*",
      "@midscene/web": "workspace:*",
      "@midscene/computer": "workspace:*",
      "@midscene/android": "workspace:*",
      "@midscene/ios": "workspace:*",
      "@midscene/harmony": "workspace:*",
      "@midscene/visualizer": "workspace:*",
      "@midscene/shared": "workspace:*"
    }
  }
}
